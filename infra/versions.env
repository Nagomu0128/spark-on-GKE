# Pinned tool/component versions. Verify the latest before bumping (the design
# doc §15 mandates pinning — no "-latest"). Sourced by helper scripts and used as
# documentation.

# Spark 3.5 LTS line. Verify: https://spark.apache.org/downloads.html
SPARK_VERSION=3.5.6
SCALA_VERSION=2.12
JAVA_VERSION=17

# GCS connector for Hadoop3. The hadoop-lib bucket hosts the shaded jar as
# gcs-connector-hadoop3-<ver>.jar (no -shaded suffix). Pin a concrete version.
# Verify: https://github.com/GoogleCloudDataproc/hadoop-connectors/releases
GCS_CONNECTOR_VERSION=2.2.33

# Kubeflow Spark Operator Helm chart (v2.x).
# Verify: https://github.com/kubeflow/spark-operator/releases
SPARK_OPERATOR_CHART_VERSION=2.1.0

# Apache Airflow Helm chart.
# Verify: https://airflow.apache.org/docs/helm-chart/stable/
AIRFLOW_CHART_VERSION=1.15.0

# Airflow cncf.kubernetes provider (SparkKubernetesOperator). Bundled by the
# Airflow chart's image (chart 1.15.0 -> apache/airflow 2.9.3 ships 8.3.3), not
# installed separately. Verify with `airflow providers list` after deploy.
# https://pypi.org/project/apache-airflow-providers-cncf-kubernetes/
AIRFLOW_K8S_PROVIDER_VERSION=8.3.3

# Terraform google provider major.
# Verify: https://registry.terraform.io/providers/hashicorp/google/latest
GOOGLE_PROVIDER_VERSION=6.0

# Hadoop image for the optional HDFS/YARN learning module (Phase 7, Appendix G).
# Pinned in manifests/hdfs/*.yaml; recorded here for reference.
# Verify: https://hub.docker.com/r/apache/hadoop/tags
HADOOP_VERSION=3.3.6
